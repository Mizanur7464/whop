# ============================================================
# Whop x Telegram x Airtable - Environment Variables
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file and rename to ".env"
# 2. Replace all "YOUR_..." values with real credentials
# 3. NEVER commit .env to git (already in .gitignore)
# ============================================================

# -------- TELEGRAM --------
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_BOT_USERNAME=YOUR_BOT_USERNAME

# -------- TWO-GROUP LAYOUT --------
# Group 1: Welcome supergroup (pinned Whop link + admin-only notifications topic)
TELEGRAM_WELCOME_GROUP_ID=-100XXXXXXXXXX
TELEGRAM_WELCOME_GROUP_TOPIC_WELCOME=2
TELEGRAM_WELCOME_GROUP_TOPIC_NOTIFICATIONS=4

# Group 2: Main community (no welcome topic — use bot DM for onboarding)
TELEGRAM_COMMUNITY_LAYOUT=topics
TELEGRAM_MAIN_GROUP_ID=-100XXXXXXXXXX
TELEGRAM_TOPIC_WELCOME=
TELEGRAM_TOPIC_COPYTRADING=
TELEGRAM_TOPIC_OFFBOARD=
TELEGRAM_TOPIC_SUPPORT=
TELEGRAM_TOPIC_SIGNALS=
TELEGRAM_TOPIC_EDUCATION=
TELEGRAM_TOPIC_NOTIFICATIONS=
TELEGRAM_TOPIC_PNL=

TELEGRAM_VIP_GROUP_ID=-100XXXXXXXXXX
TELEGRAM_ANNOUNCEMENT_CHANNEL_ID=-100XXXXXXXXXX

# Admin Telegram user IDs (comma-separated, no spaces)
TELEGRAM_ADMIN_IDS=123456789,987654321

# Onboarding screenshot reviewers (Approve/Reject). Only these admins get screenshots.
# If empty, falls back to TELEGRAM_ADMIN_IDS.
TELEGRAM_REVIEW_ADMIN_IDS=123456789

# Existing members who already have full access (skip onboarding) — optional
TELEGRAM_GRANDFATHER_IDS=

# -------- WHOP --------
# Get from Whop Dashboard > Developer > API Keys
WHOP_API_KEY=YOUR_WHOP_API_KEY_HERE
WHOP_COMPANY_ID=biz_XXXXXXXXXX
WHOP_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE
# true = free Whop registration (no payment wording). false = paid membership copy.
WHOP_FREE_ACCESS=true

# Product/Plan IDs from Whop (comma-separated if multiple)
WHOP_PRODUCT_BASIC=prod_XXXXXXXXXX
WHOP_PRODUCT_PREMIUM=prod_XXXXXXXXXX
WHOP_PRODUCT_VIP=prod_XXXXXXXXXX

# -------- AIRTABLE --------
# Get from https://airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table names (will be auto-created in Phase 5)
AIRTABLE_MEMBERS_TABLE=Members
AIRTABLE_FINANCE_TABLE=Payments
AIRTABLE_PAYMENTS_TABLE=Payments
AIRTABLE_EXPENSES_TABLE=Expenses
AIRTABLE_CHECKLIST_TABLE=Checklist
# Unified finance: set AIRTABLE_FINANCE_TABLE=Payments and add columns
# Type, Fees, Net Amount, Currency (select EUR/USD/GBP) to Payments table.

# -------- EMAIL (offboard / support forms) --------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=info@fusionwealthcapital.com
FUSION_EMAIL_TO=info@fusionwealthcapital.com

# -------- APP SETTINGS --------
ENVIRONMENT=development
LOG_LEVEL=INFO
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_PATH=/webhook/whop

# -------- ROLLOUT / SAFETY --------
# SAFE_MODE=true disables any disruptive actions (kicks, broadcasts, etc.)
SAFE_MODE=true
# Delete any non-admin message in TELEGRAM_MAIN_GROUP_ID (bot needs delete_messages right)
GROUP_MODERATION_DELETE_MEMBER_MESSAGES=true
# ROLLOUT_MODE:
#   - new_only: only new members go through onboarding/unlock
#   - everyone: everyone can go through onboarding/unlock
ROLLOUT_MODE=new_only

# Legacy separate channels (only if TELEGRAM_COMMUNITY_LAYOUT=channels)
# TELEGRAM_WELCOME_CHANNEL_ID=-100XXXXXXXXXX
# TELEGRAM_COPYTRADING_CHANNEL_ID=-100XXXXXXXXXX

# Public URL where Whop will send webhooks (set after deploying)
PUBLIC_WEBHOOK_URL=https://your-app.up.railway.app/webhook/whop

# Optional app origin (no path). If empty, derived from PUBLIC_WEBHOOK_URL host.
# Whop success redirect: https://your-app.up.railway.app/whop/success?membership_id={membership_id}
PUBLIC_APP_BASE_URL=https://your-app.up.railway.app

# -------- BUYER PDF DOCUMENTS (Google Drive source URLs) --------
# Bot sends local copies from data/docs/ (see data/layout/*.json).
# Re-sync when buyer sends new Drive links: python scripts/sync_buyer_pdfs.py
DOC_URL_TERMS=https://drive.google.com/file/d/1emxNyLVx1PsQAIp7V0Gj7NNgDAIwnkD3/view?usp=sharing
DOC_URL_ONBOARDING_VANTAGE=https://drive.google.com/file/d/1GRt27e2iTl_HW5e11bIH0HjzEyeY7mlh/view?usp=sharing
DOC_URL_ONBOARDING_PREMIER=https://drive.google.com/file/d/1XllSbhKCrrA7QewGMqtNyZMoazYFMixz/view?usp=sharing
DOC_URL_COPYTRADING_VANTAGE=https://drive.google.com/file/d/1x_jzPM8B5SDk-eCzR3QJL7NKAq_pNJ6x/view?usp=sharing
DOC_URL_COPYTRADING_PREMIER=https://drive.google.com/file/d/1l-akMVYoq56LqfE8tbO3vsyeMxcb8Lpw/view?usp=sharing
